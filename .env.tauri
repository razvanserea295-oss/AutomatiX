# Loaded ONLY for the Tauri desktop build (`vite build --mode tauri`).
# The desktop shell bundles the SPA and talks to the Promix server over HTTP;
# this is the default server URL it points at on first launch (the common case:
# the app runs on the same PC as the server). It is overridable in-app via the
# setup wizard / Settings, and is IGNORED by the normal web build (which is
# served by the server and always uses its own origin).
VITE_DEFAULT_SERVER_URL=http://localhost:3500
