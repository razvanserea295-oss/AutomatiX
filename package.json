{
  "name": "promix-automatix",
  "version": "1.1.7",
  "description": "automatiX — Web/server application for Industrial Operations Management",
  "author": "automatiX",
  "main": "dist-server/server/index.js",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings 80",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "build:prod": "vite build && tsc -p tsconfig.server.json",
    "start": "node --env-file-if-exists=.env dist-server/server/index.js",
    "server": "tsc -p tsconfig.server.json && node --env-file-if-exists=.env dist-server/server/index.js",
    "demo": "vite build && tsc -p tsconfig.server.json && node scripts/serve-demo.cjs",
    "server:dev": "concurrently \"vite\" \"tsc -p tsconfig.server.json && node dist-server/server/index.js\"",
    "version:stamp": "node scripts/stamp-version.mjs",
    "build:installer": "node scripts/stamp-version.mjs && powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "ship": "bash scripts/ship.sh",
    "ship:minor": "bash scripts/ship.sh minor",
    "ship:major": "bash scripts/ship.sh major",
    "build": "tsc && vite build",
    "build:tauri-frontend": "vite build --mode tauri && node scripts/trim-tauri-dist.cjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "design-index": "tsx scripts/design-system-indexer.ts",
    "design-index:docs": "tsx scripts/design-system-indexer.ts && node scripts/generate-design-docs.mjs",
    "tauri:build": "tauri build",
    "tauri:publish": "node scripts/publish-tauri-update.mjs",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:app": "npm run build:web && npm run build:server",
    "deploy:web": "npm run build:web",
    "preview": "vite preview",
    "check:migration": "node scripts/check-migration.mjs",
    "test": "vitest --run",
    "test:cov": "vitest --run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "support:prepare-bundle": "node scripts/prepare-quicksupport.mjs",
    "support:setup-rustdesk": "node scripts/setup-rustdesk-env.mjs",
    "support:install-relay": "powershell -ExecutionPolicy Bypass -File scripts/install-rustdesk-server-windows.ps1",
    "support:enable-public": "powershell -ExecutionPolicy Bypass -File scripts/enable-rustdesk-public.ps1",
    "server:restart": "powershell -ExecutionPolicy Bypass -File scripts/restart-server.ps1"
  },
  "dependencies": {
    "@bite-ninja/rustdesk-client-web": "^0.2.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@sentry/node": "^8.55.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/react-window": "^1.8.8",
    "@ui5/webcomponents": "^2.23.1",
    "@ui5/webcomponents-fiori": "^2.23.1",
    "@ui5/webcomponents-icons": "^2.23.1",
    "@ui5/webcomponents-react": "^2.23.1",
    "archiver": "^8.0.0",
    "cfb": "^1.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dompurify": "^3.4.9",
    "dxf": "^5.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "extract-zip": "^2.0.1",
    "framer-motion": "^12.38.0",
    "hash-wasm": "^4.11.0",
    "helmet": "^8.1.0",
    "imap": "^0.8.19",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.441.0",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "otpauth": "^9.5.1",
    "pdf-to-printer": "^5.8.0",
    "pdfmake": "^0.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "sonner": "^2.0.7",
    "sql.js": "^1.11.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^10.0.0",
    "wouter": "^3.9.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/imap": "^0.8.43",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "playwright": "^1.61.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.5",
    "vitest": "^4.1.2"
  }
}
