{
  "name": "promix-automatix",
  "version": "1.1.4",
  "description": "automatiX — Web/server application for Industrial Operations Management",
  "author": "automatiX",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:prod": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "server": "tsc -p tsconfig.server.json && node dist-server/server/index.js",
    "demo": "vite build && tsc -p tsconfig.server.json && node scripts/serve-demo.cjs",
    "server:dev": "concurrently \"vite\" \"tsc -p tsconfig.server.json && node dist-server/server/index.js\"",
    "version:stamp": "node scripts/stamp-version.mjs",
    "ship": "bash scripts/ship.sh",
    "ship:minor": "bash scripts/ship.sh minor",
    "ship:major": "bash scripts/ship.sh major",
    "build": "tsc && vite build",
    "build:tauri-frontend": "vite build --mode tauri && node scripts/trim-tauri-dist.cjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:publish": "node scripts/publish-tauri-update.mjs",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:app": "npm run build:web && npm run build:server",
    "deploy:web": "npm run build:web",
    "deploy:electron": "npm run build:electron",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "monitor": "node scripts/monitor-dev.mjs",
    "icon:gen": "node scripts/make-icon.mjs",
    "build:electron-ts": "tsc -p tsconfig.electron.json",
    "build:electron": "node scripts/make-icon.mjs && vite build && tsc -p tsconfig.server.json && node -e \"require('fs').copyFileSync('package.json','dist-server/package.json')\" && tsc -p tsconfig.electron.json && electron-builder && node scripts/publish-installer.mjs",
    "dist:electron:win": "node scripts/make-icon.mjs && vite build && tsc -p tsconfig.server.json && node -e \"require('fs').copyFileSync('package.json','dist-server/package.json')\" && tsc -p tsconfig.electron.json && electron-builder --win nsis && node scripts/publish-installer.mjs",
    "dev:electron": "node scripts/dev-electron.mjs"
  },
  "dependencies": {
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/react-window": "^1.8.8",
    "@ui5/webcomponents": "^2.23.1",
    "@ui5/webcomponents-fiori": "^2.23.1",
    "@ui5/webcomponents-icons": "^2.23.1",
    "@ui5/webcomponents-react": "^2.23.1",
    "archiver": "^8.0.0",
    "cfb": "^1.2.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dompurify": "^3.4.9",
    "dxf": "^5.3.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "extract-zip": "^2.0.1",
    "framer-motion": "^12.38.0",
    "hash-wasm": "^4.11.0",
    "helmet": "^8.1.0",
    "imap": "^0.8.19",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.441.0",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "otpauth": "^9.5.1",
    "pdfmake": "^0.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "sql.js": "^1.11.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^10.0.0",
    "wouter": "^3.9.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/imap": "^0.8.43",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^37.10.3",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.5",
    "vitest": "^4.1.2"
  }
}
