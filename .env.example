# =============================================================================
# Promix Automatix — environment variables for the web/server deployment.
# Copy to `.env` and fill in. NEVER commit a real `.env` (it's git-ignored).
# Used by docker-compose.yml and read directly by the Node server.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED for a public deployment
# -----------------------------------------------------------------------------
# Your public domain (DNS A/AAAA record must point at this host). Caddy issues
# and renews a Let's Encrypt certificate for it automatically.
PROMIX_DOMAIN=app.example.com

# AES-256 key (64 hex chars) for the at-rest encrypted database. Generate with:
#   openssl rand -hex 32
# If left empty, the app generates data/.dbkey on first boot — back that file up
# off-server. If this key is lost, the database AND all backups are unrecoverable.
PROMIX_DB_KEY=

# -----------------------------------------------------------------------------
# Server (sensible defaults shown — override only if needed)
# -----------------------------------------------------------------------------
# Listen port inside the container (Caddy proxies to it; no need to publish it).
PROMIX_PORT=3500

# Set to 1 when behind a reverse proxy / CDN (the compose stack does this for
# you) so audit logs and rate limiting see real client IPs via X-Forwarded-For.
PROMIX_TRUST_PROXY=1

# Network interface to bind. DEFAULT: loopback only (127.0.0.1) — the server is
# NOT reachable from the LAN/internet unless you opt in. Binds all interfaces
# automatically when PROMIX_TRUST_PROXY=1 (proxy in front).
#   • LAN / tablet deployment (no proxy): set PROMIX_LAN=1 so tablets can reach
#     http://<this-pc-ip>:3500. Without it, only this PC can connect.
#   • Or pin the interface explicitly (wins over everything): PROMIX_BIND_HOST=0.0.0.0
# PROMIX_LAN=1
# PROMIX_BIND_HOST=0.0.0.0

# CORS allowlist (comma-separated, no trailing slash). STRICT by default: only
# same-origin + loopback (localhost/127.0.0.1, any port — so Vite :5173 dev works)
# are allowed; every other origin is rejected so a malicious site can't ride a
# logged-in session. List your web client origins when serving cross-origin.
# A literal "*" allows ALL origins (dev/diagnostic only — logged loudly at boot).
# PROMIX_ALLOWED_ORIGINS=https://automatix.online,http://localhost:5173

# JSON body cap on /api/cmd. Default 500mb (allows large inline attachments).
# LOWER this (e.g. 50mb) on internet-facing deployments that don't need big
# inline uploads — an oversized body is a DoS/OOM vector.
# PROMIX_BODY_LIMIT=500mb

# Set to 1 to disable per-IP rate limits (LAN dev only — never in production).
# PROMIX_RATE_LIMIT_OFF=0

# -----------------------------------------------------------------------------
# Email (optional — only if the app sends/receives mail)
# -----------------------------------------------------------------------------
# TLS certificate validation for SMTP *and* IMAP is ON by default (recommended).
# A self-signed / misconfigured mail server will fail to connect rather than
# silently accepting a MITM-able session. Set to `true` ONLY for an internal
# relay with a self-signed certificate — it's logged loudly at server boot.
# PROMIX_ALLOW_INSECURE_SMTP=true

# -----------------------------------------------------------------------------
# AI service (optional — separate Rust process, not in the app container)
# -----------------------------------------------------------------------------
# Bearer token shared between the app and the ai-service (also store it in the
# UI under Settings → AI service token). Generate with: openssl rand -hex 32
# AI_SERVICE_TOKEN=

# The ai-service authenticates to the ERP as this account. REQUIRED if you run
# the AI service — the service refuses to start with the CHANGE_ME placeholder.
# PROMIX_SERVICE_USERNAME=ai-service
# PROMIX_SERVICE_PASSWORD=

# Inference backend for the AI service.
# OLLAMA_HOST=http://127.0.0.1:11434
# RUST_LOG=warn

# -----------------------------------------------------------------------------
# Production checklist
# -----------------------------------------------------------------------------
# [ ] PROMIX_DOMAIN set + DNS points here; ports 80/443 open
# [ ] PROMIX_DB_KEY generated and backed up off-server
# [ ] First login as admin forces a password change (migration 099) — do it
# [ ] PROMIX_ALLOWED_ORIGINS locked to your domain (compose does this)
# [ ] Bind: behind a proxy → PROMIX_TRUST_PROXY=1 (auto 0.0.0.0). LAN/tablets w/o
#     proxy → PROMIX_LAN=1. Otherwise it listens on 127.0.0.1 only.
# [ ] data/ volume is backed up (holds DB + key + rolling backups)
# [ ] If using email: PROMIX_ALLOW_INSECURE_SMTP unset (verify TLS certs)
# [ ] If using AI: PROMIX_SERVICE_PASSWORD + AI_SERVICE_TOKEN set
